# Script to create sub-issues for broken Markdown links.
#
# Usage: create_broken_link_issues <failures-json> <parent-issue-number>
#
# Arguments:
#
#   failures-json        JSON array of broken link failures.
#   parent-issue-number  Number of the parent tracking issue.
#
# Environment variables:
#
#   GITHUB_TOKEN         GitHub authentication token.
#   DRY_RUN              Set to 1 to enable dry run mode (no issues created).
#

# shellcheck disable=SC2153,SC2317

# Ensure that the exit status of pipelines is non-zero in the event that at least one of the commands in a pipeline fails:
set -o pipefail

# Exit immediately if a command exits with a non-zero status:
set -e


# VARIABLES #

# Assign command line arguments to variables:
failures_json="$1"
parent_issue_number="$2"

# Repository information:
owner="stdlib-js"
repo="stdlib"

# GitHub API base URL:
GITHUB_API_URL="https://api.github.com"

# Get the GitHub authentication token:
github_token="${GITHUB_TOKEN}"
if [ -z "$github_token" ]; then
	echo "ERROR: GITHUB_TOKEN environment variable is not set." >&2
	exit 1
fi

# Dry run mode:
dry_run="${DRY_RUN:-0}"


# FUNCTIONS #

# Error handler.
#
# $1 - error status code
on_error() {
	echo "ERROR: An error was encountered during execution." >&2
	exit "$1"
}

# Prints a success message.
print_success() {
	echo "Success!" >&2
}

# Makes a GitHub API GET request.
#
# $1 - API endpoint
github_api() {
	local endpoint="$1"
	local headers=( "-H" "User-Agent: GitHub-API-Script" \
		"-H" "Authorization: token ${github_token}" \
		"-H" "Accept: application/vnd.github+json")

	local response
	if ! response=$(curl -s --fail-with-body "${headers[@]}" "${GITHUB_API_URL}${endpoint}"); then
		echo "ERROR: GitHub API request failed for endpoint: ${endpoint}" >&2
		return 1
	fi
	echo "$response"
}

# Makes a GitHub GraphQL API request.
#
# $1 - GraphQL query/mutation JSON
github_graphql() {
	local query="$1"
	local response
	if ! response=$(curl -s --fail-with-body -X POST 'https://api.github.com/graphql' \
		-H "Authorization: bearer ${github_token}" \
		-H "Content-Type: application/json" \
		-H "GraphQL-Features: issue_types" \
		-H "GraphQL-Features: sub_issues" \
		--data "$query"); then
		echo "ERROR: GitHub GraphQL API request failed." >&2
		return 1
	fi
	echo "$response"
}

# Fetches the repository node ID.
fetch_repo_id() {
	local response
	response=$(github_graphql "{
		\"query\": \"query(\$owner: String!, \$repo: String!) { repository(owner: \$owner, name: \$repo) { id } }\",
		\"variables\": {
			\"owner\": \"${owner}\",
			\"repo\": \"${repo}\"
		}
	}")
	echo "$response" | jq -r '.data.repository.id'
}

# Fetches the parent issue ID.
fetch_parent_issue_id() {
	local response
	response=$(github_graphql "{
		\"query\": \"query(\$owner: String!, \$repo: String!, \$number: Int!) { repository(owner: \$owner, name: \$repo) { issue(number: \$number) { id } } }\",
		\"variables\": {
			\"owner\": \"${owner}\",
			\"repo\": \"${repo}\",
			\"number\": ${parent_issue_number}
		}
	}")
	echo "$response" | jq -r '.data.repository.issue.id'
}

# Fetches label IDs for the "Good First Issue" label.
fetch_label_id() {
	local response
	response=$(github_graphql "{
		\"query\": \"query(\$owner: String!, \$repo: String!) { repository(owner: \$owner, name: \$repo) { labels(first: 100) { nodes { id name } } } }\",
		\"variables\": {
			\"owner\": \"${owner}\",
			\"repo\": \"${repo}\"
		}
	}")

	# Extract the ID for "Good First Issue" label:
	echo "$response" | jq -r '.data.repository.labels.nodes[] | select(.name == "Good First Issue") | .id'
}

# Checks whether an issue already exists for the given URL.
#
# $1 - URL to check
issue_exists_for_url() {
	local url="$1"
	local query

	# Build a search query that looks for the URL in the issue body:
	local raw_query="repo:${owner}/${repo} is:issue \"${url}\" in:body"

	# URL-encode the query using jq (use printf to avoid trailing newline):
	query=$(printf '%s' "$raw_query" | jq -sRr @uri)

	local endpoint="/search/issues?q=${query}"
	local response
	if ! response=$(github_api "$endpoint"); then
		echo "  Warning: Search API failed, assuming issue doesn't exist." >&2
		return 1  # Assume issue doesn't exist, let it try to create
	fi

	if ! echo "$response" | jq . >/dev/null 2>&1; then
		echo "  Warning: Invalid JSON from search API, assuming issue doesn't exist." >&2
		return 1  # Assume issue doesn't exist
	fi

	local total_count
	total_count=$(echo "$response" | jq -r '.total_count')

	if [ -z "$total_count" ] || [ "$total_count" = "null" ]; then
		return 1  # Couldn't determine, assume doesn't exist
	fi

	if [ "$total_count" -gt 0 ] 2>/dev/null; then
		return 0  # Issue exists
	else
		return 1  # Issue doesn't exist
	fi
}

# Creates a child issue.
#
# $1 - repository node ID
# $2 - issue title
# $3 - issue body
# $4 - label ID
create_child_issue() {
	local repo_id="$1"
	local issue_title="$2"
	local issue_body="$3"
	local label_id="$4"

	local label_ids="[]"
	if [ -n "$label_id" ]; then
		label_ids="[\"${label_id}\"]"
	fi

	local response
	response=$(curl -s -X POST 'https://api.github.com/graphql' \
		-H "Authorization: bearer ${github_token}" \
		-H "Content-Type: application/json" \
		--data @- << EOF
{
	"query": "mutation CreateIssue(\$repositoryId: ID!, \$title: String!, \$body: String!, \$labelIds: [ID!]) { createIssue(input: {repositoryId: \$repositoryId, title: \$title, body: \$body, labelIds: \$labelIds}) { issue { id number } } }",
	"variables": {
		"repositoryId": "${repo_id}",
		"title": $(echo "$issue_title" | jq -R '.'),
		"body": $(echo "$issue_body" | jq -R -s '.'),
		"labelIds": ${label_ids}
	}
}
EOF
)
	echo "$response"
}

# Creates a sub-issue relationship.
#
# $1 - parent issue ID
# $2 - child issue ID
create_sub_issue_relationship() {
	local parent_issue_id="$1"
	local child_issue_id="$2"
	local response
	response=$(github_graphql "{
		\"query\": \"mutation(\$parentIssueId: ID!, \$childIssueId: ID!) { addSubIssue(input: { issueId: \$parentIssueId, subIssueId: \$childIssueId }) { issue { number } subIssue { number } } }\",
		\"variables\": {
			\"parentIssueId\": \"${parent_issue_id}\",
			\"childIssueId\": \"${child_issue_id}\"
		}
	}")
	echo "$response"
}

# Main execution sequence.
main() {
	# Validate inputs:
	if [ -z "$failures_json" ]; then
		echo "ERROR: No failures JSON provided." >&2
		exit 1
	fi

	if [ -z "$parent_issue_number" ]; then
		echo "ERROR: No parent issue number provided." >&2
		exit 1
	fi

	# Parse the failures JSON:
	local num_failures
	num_failures=$(echo "$failures_json" | jq 'length')

	if [ "$num_failures" -eq 0 ] || [ "$num_failures" = "null" ]; then
		echo "No broken links found." >&2
		print_success
		exit 0
	fi

	echo "Found ${num_failures} broken link(s)." >&2

	if [ "$dry_run" -eq 1 ]; then
		echo "" >&2
		echo "=== DRY RUN MODE ===" >&2
		echo "No issues will be created." >&2
		echo "" >&2
	fi

	# Fetch repository and parent issue IDs (skip in dry run mode):
	local repo_id=""
	local parent_issue_id=""
	local label_id=""

	if [ "$dry_run" -ne 1 ]; then
		echo "Fetching repository node ID..." >&2
		repo_id=$(fetch_repo_id)
		if [ -z "$repo_id" ] || [ "$repo_id" = "null" ]; then
			echo "ERROR: Failed to fetch repository ID." >&2
			exit 1
		fi

		echo "Fetching parent issue #${parent_issue_number}..." >&2
		parent_issue_id=$(fetch_parent_issue_id)
		if [ -z "$parent_issue_id" ] || [ "$parent_issue_id" = "null" ]; then
			echo "ERROR: Failed to fetch parent issue ID." >&2
			exit 1
		fi

		echo "Fetching label ID..." >&2
		label_id=$(fetch_label_id)
	fi

	# Process each failure:
	local i=0
	local created_count=0
	local skipped_exists=0
	local skipped_false_positives=0

	while [ "$i" -lt "$num_failures" ]; do
		local failure
		failure=$(echo "$failures_json" | jq -c ".[$i]")

		local url
		url=$(echo "$failure" | jq -r '.url')

		local code
		code=$(echo "$failure" | jq -r '.code')

		local status
		status=$(echo "$failure" | jq -r '.status')

		local file
		file=$(echo "$failure" | jq -r '.file')

		# Strip CI runner path prefix:
		file="${file#/home/runner/work/stdlib/stdlib/}"

		echo "Processing broken link: ${url}" >&2

		# Skip rate-limited URLs (429) - not actually broken:
		if [ "$code" != "null" ] && [ "$code" -eq 429 ] 2>/dev/null; then
			echo "  Skipping: rate-limited (429), not a broken link." >&2
			skipped_false_positives=$((skipped_false_positives + 1))
			i=$((i + 1))
			continue
		fi

		# Skip forbidden URLs (403) - often caused by bot blocking, not broken links:
		if [ "$code" != "null" ] && [ "$code" -eq 403 ] 2>/dev/null; then
			echo "  Skipping: forbidden (403), likely bot-blocked - verify manually if needed." >&2
			skipped_false_positives=$((skipped_false_positives + 1))
			i=$((i + 1))
			continue
		fi

		# Check if an issue already exists for this URL:
		local issue_exists=false
		if issue_exists_for_url "$url"; then
			issue_exists=true
		fi

		if [ "$issue_exists" = true ]; then
			echo "  Skipping: issue already exists for this URL." >&2
			skipped_exists=$((skipped_exists + 1))
		else
			# Create issue title and body:
			local issue_title="Fix broken Markdown link: ${url}"

			# Truncate title if too long (GitHub limit is 256 characters):
			if [ ${#issue_title} -gt 256 ]; then
				issue_title="${issue_title:0:253}..."
			fi

			local file_url="https://github.com/${owner}/${repo}/blob/develop/${file}"

			local issue_body="## Broken Markdown Link

A broken link was detected in the automated Markdown links workflow.

### Details

- **URL:** [${url}](${url})
- **HTTP Status:** ${code} (${status})
- **File:** [\`${file}\`](${file_url})

### Instructions

1. **Verify** the link is still broken (it may be a temporary issue).
2. **Investigate** what happened to the resource:
   - Check the [Wayback Machine](https://web.archive.org/web/*/${url}) for archived versions.
   - Search for the resource at a new location.
   - Determine if the resource has been permanently removed.
3. **Fix** using one of these approaches:
   - Update with the correct/new URL if the resource moved.
   - Link to an archived version if appropriate.
   - Remove the link if the resource no longer exists and no suitable replacement can be found.
   - Replace with an alternative resource that serves the same purpose.

### Pull Request Instructions

- Please use the following PR title format:
  \`docs: fix broken Markdown link (issue #<ISSUE_NUMBER>)\`
- Reference this issue in the \"Related Issues\" section of the PR body as \`resolves #<ISSUE_NUMBER>\`.

---

This issue was created automatically by the Markdown links workflow."

			if [ "$dry_run" -eq 1 ]; then
				echo "  [DRY RUN] Would create issue:" >&2
				echo "    Title: ${issue_title}" >&2
				echo "    URL: ${url}" >&2
				echo "    HTTP Status: ${code} (${status})" >&2
				echo "    File: ${file}" >&2
				echo "    Parent: #${parent_issue_number}" >&2
				echo "    Label: Good First Issue" >&2
				created_count=$((created_count + 1))
			else
				echo "  Creating issue..." >&2
				local child_issue_response
				child_issue_response=$(create_child_issue "$repo_id" "$issue_title" "$issue_body" "$label_id")

				local child_issue_id
				child_issue_id=$(echo "$child_issue_response" | jq -r '.data.createIssue.issue.id')

				local child_issue_number
				child_issue_number=$(echo "$child_issue_response" | jq -r '.data.createIssue.issue.number')

				if [ -z "$child_issue_id" ] || [ "$child_issue_id" = "null" ]; then
					echo "  ERROR: Failed to create issue. Response: ${child_issue_response}" >&2
				else
					echo "  Created issue #${child_issue_number}" >&2

					# Create sub-issue relationship:
					echo "  Creating sub-issue relationship..." >&2
					local sub_issue_response
					sub_issue_response=$(create_sub_issue_relationship "$parent_issue_id" "$child_issue_id")

					local sub_issue_success
					sub_issue_success=$(echo "$sub_issue_response" | jq -r '.data.addSubIssue.subIssue.number')

					if [ -z "$sub_issue_success" ] || [ "$sub_issue_success" = "null" ]; then
						echo "  WARNING: Failed to create sub-issue relationship. Response: ${sub_issue_response}" >&2
					else
						echo "  Successfully linked as sub-issue of #${parent_issue_number}" >&2
					fi

					created_count=$((created_count + 1))
				fi
			fi
		fi

		i=$((i + 1))

		# Add a small delay to avoid rate limiting (skip in dry run mode):
		if [ "$dry_run" -ne 1 ]; then
			sleep 1
		fi
	done

	echo "" >&2
	if [ "$dry_run" -eq 1 ]; then
		echo "Summary (dry run): Would create ${created_count} issue(s), skipped ${skipped_exists} (already exist), skipped ${skipped_false_positives} (false positives)." >&2
	else
		echo "Summary: Created ${created_count} issue(s), skipped ${skipped_exists} (already exist), skipped ${skipped_false_positives} (false positives)." >&2
	fi

	print_success
	exit 0
}

# Set an error handler to capture errors and perform any clean-up tasks:
trap 'on_error $?' ERR

# Run main:
main
